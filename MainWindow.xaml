<Window x:Class="VRTrainingLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VR Training Launcher" Height="250" Width="400">

    <Grid Margin="20">
        <StackPanel>

            <TextBlock
                x:Name="StatusText"
                Text="Checking installation..."
                FontSize="16"
                Margin="0,0,0,20"/>

            <ProgressBar
                x:Name="ProgressBar"
                Height="20"
                Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal">

                <Button
                    x:Name="InstallButton"
                    Content="Install / Update"
                    Width="120"
                    Margin="0,0,10,0"
                    Click="InstallButton_Click"/>

                <Button
                    x:Name="LaunchButton"
                    Content="Launch"
                    Width="100"
                    Click="LaunchButton_Click"/>

            </StackPanel>

        </StackPanel>
    </Grid>
</Window>